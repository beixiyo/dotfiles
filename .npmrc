registry=https://registry.npmjs.org/
//registry.npmjs.org/:_authToken=${NPM_TOKEN}

# npm install-script 白名单需要 npm >= 11.16.0；
# 当前用 npm 11.17.0+，支持 allow-scripts / strict-allow-scripts
# 不要设 ignore-scripts=true：它会覆盖 allow-scripts，导致白名单失效
ignore-scripts=false

# 只允许白名单里的包执行 preinstall / install / postinstall
# 未覆盖的依赖脚本会被 strict-allow-scripts 拦住，避免默认执行恶意脚本
strict-allow-scripts=true
allow-scripts=opencode-ai
