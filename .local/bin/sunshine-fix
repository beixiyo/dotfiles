#!/usr/bin/env bash
#
# sunshine-fix — 修复 Sunshine 偶发"连不上"（编码器卡死）
# ============================================================================
#
# 它能修什么（且仅此一种）：
#   NVIDIA 机器上，Sunshine 的 NVENC/CUDA 上下文泄漏 → 编码器探测卡在
#   "Trying encoder" 出不来 → 看门狗强杀(SIGTRAP) → 重启后仍卡死的自循环
#   手段：重载 nvidia_uvm 模块，清掉泄漏的 CUDA 状态，免重启系统
#
# 它【不能】修什么（诚实边界，遇到请别指望本脚本）：
#   - 非 NVENC 的"连不上"：网络/防火墙(47984-48010,TCP+UDP)、配对失效、
#     客户端编码器选错、Moonlight 端配置 —— 这些跟本脚本无关
#   - AMD(VAAPI/AMF) / Intel(QSV) 显卡：没有 nvidia_uvm 这个模块，本脚本
#     对它们只会"重启一下服务"，真卡死的硬件编码器通常只能靠【重启系统】
#   - nvidia_uvm 被占用(refcount≠0，如正在跑 CUDA/深度学习)：rmmod 会失败，
#     脚本会跳过重载、退回到仅重启服务；彻底修复需关掉 CUDA 程序或重启系统
#   - 多 GPU / 同机有 CUDA 任务：重载 uvm 会重置【全机】CUDA 上下文，可能
#     打断正在跑的 CUDA 程序。介意请改用重启系统
#   - 非 systemd 的发行版：本脚本依赖 systemctl，不适用
#
# 依赖：bash、systemd、sudo(仅模块重载需要)
# ============================================================================

set -uo pipefail   # 故意不加 -e：rmmod 失败时仍要把服务重新拉起来

log()  { printf '\033[1;34m>>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*" >&2; }
err()  { printf '\033[1;31mxx\033[0m %s\n' "$*" >&2; }

# --- 1. 自动探测 Sunshine 的 systemd 单元（用户级优先，再找系统级）------------
SCOPE="" UNIT=""
detect_unit() {
  local u
  u=$(systemctl --user list-unit-files --type=service --no-legend 2>/dev/null \
        | awk '{print $1}' | grep -iE 'sunshine' | head -n1)
  if [ -n "${u:-}" ]; then SCOPE="user"; UNIT="$u"; return 0; fi

  u=$(systemctl list-unit-files --type=service --no-legend 2>/dev/null \
        | awk '{print $1}' | grep -iE 'sunshine' | head -n1)
  if [ -n "${u:-}" ]; then SCOPE="system"; UNIT="$u"; return 0; fi

  return 1
}

# 按作用域执行 systemctl（系统级需要 sudo）
sctl() {
  if [ "$SCOPE" = "user" ]; then systemctl --user "$@"
  else sudo systemctl "$@"; fi
}

if ! detect_unit; then
  err "没找到 Sunshine 的 systemd 单元。请确认已用 systemd 方式安装并启用。"
  err "手动查看：systemctl --user list-units '*sunshine*' ；systemctl list-units '*sunshine*'"
  exit 1
fi
log "目标服务：$UNIT （$SCOPE 级）"

# --- 2. 检测显卡是否 NVIDIA，以及 uvm 是否已加载 -----------------------------
IS_NVIDIA=0 UVM_LOADED=0
if [ -e /proc/driver/nvidia/version ] || lsmod | grep -q '^nvidia '; then IS_NVIDIA=1; fi
if lsmod | grep -q '^nvidia_uvm'; then UVM_LOADED=1; fi

# --- 3. 停服务 --------------------------------------------------------------
log "停止 $UNIT ..."
sctl stop "$UNIT" || true
sleep 1

# --- 4. NVIDIA：尝试重载 nvidia_uvm；非 NVIDIA 或不满足条件则诚实跳过 --------
did_reload=0
if [ "$IS_NVIDIA" -ne 1 ]; then
  warn "未检测到 NVIDIA 显卡 —— nvidia_uvm 重载不适用（AMD/Intel 的硬编卡死通常需重启系统）。"
  warn "本脚本将仅重启服务，可能不足以修复。"
elif [ "$UVM_LOADED" -ne 1 ]; then
  warn "nvidia_uvm 未加载，说明当前没有泄漏的 CUDA 状态可清；仅重启服务。"
else
  # refcount=0 才能 rmmod；停服务后若仍被占用，说明有别的 CUDA 程序在用
  refs=$(awk '/^nvidia_uvm/ {print $3}' /proc/modules)
  if [ "${refs:-0}" != "0" ]; then
    warn "nvidia_uvm 被占用 (refcount=$refs)，可能有 CUDA 程序在跑，无法重载。"
    warn "请关掉 CUDA 程序后重试，或直接重启系统。本次仅重启服务。"
  else
    log "重载 nvidia_uvm（清掉泄漏的 CUDA/NVENC 状态，需 sudo）..."
    if sudo rmmod nvidia_uvm && sudo modprobe nvidia_uvm; then
      did_reload=1
      log "nvidia_uvm 重载完成。"
    else
      err "nvidia_uvm 重载失败。若 modprobe 没成功，CUDA 会暂时不可用，建议重启系统。"
    fi
  fi
fi

# --- 5. 起服务 + 看探测结果 --------------------------------------------------
log "重启 $UNIT ..."
sctl start "$UNIT"
sleep 3

log "编码器探测结果："
journalctl ${SCOPE:+$([ "$SCOPE" = user ] && echo --user)} -u "$UNIT" -n 40 --no-pager 2>/dev/null \
  | grep -iE "Found .*encoder|Could not open codec \[(h264|hevc|av1)|Configuration UI|Trying encoder" \
  || warn "未抓到探测日志，手动看：journalctl ${SCOPE:+--user} -u $UNIT -n 50"

echo
if [ "$did_reload" -eq 1 ]; then
  log "完成（已重载 nvidia_uvm）。用 Moonlight 重连测试。"
  log "若仍卡在 'Trying encoder' 而无 'Found ... encoder' —— 那就只能重启系统了。"
else
  log "完成（仅重启了服务）。若问题依旧，按上面边界说明排查，或重启系统。"
fi
