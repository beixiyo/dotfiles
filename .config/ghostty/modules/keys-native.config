# ╭─────────────────────────────────────────────────────╮
# │   standalone 模式：Ghostty 原生 tab + split（无 tmux） │
# ╰─────────────────────────────────────────────────────╯
# 本文件在 config 中通过 `config-file` 启用；切 tmux 模式请改
# config-file = modules/keys-tmux.config
#
# ⚠️ Ghostty 无法无缝集成 smart-splits.nvim：
#   Ghostty 没有 CLI / API / 基于 app 状态的条件 keybind
#   （Kitty 有 `--when-focus-on var:XXX`，WezTerm 有 lua action_callback）
# 后果：本模式下 ctrl+alt+hjkl 在任何场景下都会被 Ghostty 吞掉切 Ghostty 窗格，
#       Nvim 内按同一组键无法被捕获 → Nvim 内窗口跳转需用 <C-w>hjkl
#
# 参考:
#   smart-splits Issue #273 (CLOSED, 作者明确不支持):
#     https://github.com/mrjones2014/smart-splits.nvim/issues/273
#   Ghostty API Discussion #2353 (停滞):
#     https://github.com/ghostty-org/ghostty/discussions/2353
# 如果需要 Nvim ↔ 终端无缝切换，优先用 tmux 模式 / Kitty / WezTerm


# --- Tab 管理（ghostty 原生 tab，tmux 模式下改用 tmux window）---
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+w=close_surface
keybind = ctrl+1=goto_tab:1
keybind = ctrl+2=goto_tab:2
keybind = ctrl+3=goto_tab:3
keybind = ctrl+4=goto_tab:4
keybind = ctrl+5=goto_tab:5
keybind = ctrl+6=goto_tab:6
keybind = ctrl+7=goto_tab:7
keybind = ctrl+8=goto_tab:8

# --- 窗格（Split）管理 ---
keybind = ctrl+alt+minus=new_split:down
keybind = ctrl+alt+backslash=new_split:right
keybind = ctrl+alt+w=close_surface

# --- 窗格切换（Ghostty 独占 ctrl+alt+hjkl，无法透传给 Nvim）---
keybind = ctrl+alt+h=goto_split:left
keybind = ctrl+alt+j=goto_split:down
keybind = ctrl+alt+k=goto_split:up
keybind = ctrl+alt+l=goto_split:right

# --- 窗格大小调整（同上，独占方向键）---
keybind = ctrl+alt+right=resize_split:right,10
keybind = ctrl+alt+left=resize_split:left,10
keybind = ctrl+alt+up=resize_split:up,10
keybind = ctrl+alt+down=resize_split:down,10
