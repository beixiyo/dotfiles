# ╭─────────────────────────────────────────────────────╮
# │        基础快捷键（真·通用，不随 tmux 模式变化）        │
# ╰─────────────────────────────────────────────────────╯
# Tab 管理 / 分屏已分别移至 standalone-keymap.config 或 tmux-keymap.config，
# 保证「二选一」互斥：终端自管 tab ↔ tmux 管 window

# --- 清除所有 Ghostty 默认快捷键 ---
# 避免默认快捷键（如 cmd+d, cmd+f 等）污染或干扰 Tmux/Nvim
keybind = clear

# --- 重新绑定必要的系统级快捷键 ---
keybind = cmd+c=copy_to_clipboard:mixed
keybind = cmd+v=paste_from_clipboard

# --- 禁用默认 Cmd+T / Cmd+W（避免 macOS 菜单抢键） ---
keybind = cmd+t=unbind
keybind = cmd+w=unbind

# --- 字体缩放 ---
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+0=reset_font_size

# --- 透传给 Neovim 的特殊键（CSI u 直注入，绕过 tmux 重编码）---
# Ctrl+`
keybind = ctrl+grave_accent=text:\x1b[96;5u
# Ctrl+Shift+l
keybind = ctrl+shift+l=text:\x1b[108;6u

# --- 其他 ---
keybind = ctrl+shift+n=new_window
keybind = ctrl+shift+v=paste_from_clipboard
