# ╭─────────────────────────────────────────────────────╮
# │                  Shader 视觉特效                     │
# ╰─────────────────────────────────────────────────────╯
# 多行同时启用会按顺序叠加（前者输出作为后者输入）


# ─── 动画：光标 / 交互特效（和文字友好，日常推荐）───
# 光标拖尾
custom-shader = ~/.config/ghostty/shaders/cursor_blaze.glsl
# 聚光灯跟随光标
# custom-shader = ~/.config/ghostty/shaders/auto-tracking-spotlight.glsl
# 缓慢漂移聚光灯
# custom-shader = ~/.config/ghostty/shaders/spotlight.glsl
# 游戏 CRT 光标辉光轨迹（配合 in-game-crt 用）
# custom-shader = ~/.config/ghostty/shaders/in-game-crt-cursor.glsl
# 游戏风格 CRT（扫描线 / 弯曲 / 暗角）
# custom-shader = ~/.config/ghostty/shaders/in-game-crt.glsl


# ─── 静态（即便 animation=false 也不影响观感，最省 CPU）───
# 泛光：亮色向外柔和扩散
custom-shader = ~/.config/ghostty/shaders/bloom.glsl
# 改良版 CRT：弯曲边框 + 扫描线
# custom-shader = ~/.config/ghostty/shaders/bettercrt.glsl
# 经典 CRT：扫描线 + 像素网格 + 色差
# custom-shader = ~/.config/ghostty/shaders/crt.glsl
# Bayer 抖动：像素 / 点阵画风格
# custom-shader = ~/.config/ghostty/shaders/dither.glsl
# 负片：颜色全部取反
# custom-shader = ~/.config/ghostty/shaders/negative.glsl
# 复古绿屏 CRT
# custom-shader = ~/.config/ghostty/shaders/retro-terminal.glsl
# TFT 液晶像素格栅叠加
# custom-shader = ~/.config/ghostty/shaders/tft.glsl


# ─── 动画：背景粒子 / 场景（华丽但可能分散注意）───
# 绿色字符雨
# custom-shader = ~/.config/ghostty/shaders/matrix-hallway.glsl
# Matrix 神秘符文雨
# custom-shader = ~/.config/ghostty/shaders/inside-the-matrix.glsl
# 3D 旋转立方体
# custom-shader = ~/.config/ghostty/shaders/cubes.glsl
# 机械齿轮与传送带
# custom-shader = ~/.config/ghostty/shaders/gears-and-belts.glsl
# 水面涟漪与反射
# custom-shader = ~/.config/ghostty/shaders/water.glsl
# 水下折射扭曲
# custom-shader = ~/.config/ghostty/shaders/underwater.glsl
# 正弦波同心干涉纹
# custom-shader = ~/.config/ghostty/shaders/sin-interference.glsl


# ─── 动画：滤镜 / 后处理 ───
# RGB 色差分离 + 泛光，通道抖动
# custom-shader = ~/.config/ghostty/shaders/glow-rgbsplit-twitchy.glsl
# 周期性数字故障
# custom-shader = ~/.config/ghostty/shaders/glitchy.glsl
# 醉酒：画面摇晃扭曲
# custom-shader = ~/.config/ghostty/shaders/drunkard.glsl
# Simplex 噪波（作为依赖用）
# custom-shader = ~/.config/ghostty/shaders/mnoise.glsl


# true = 持续动画（聚焦时）| false = 仅内容更新时渲染（动画冻结）| always = 始终动画
custom-shader-animation = true
