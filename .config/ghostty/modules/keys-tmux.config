# ╭─────────────────────────────────────────────────────╮
# │           tmux 模式（键原样透传给 tmux）             │
# ╰─────────────────────────────────────────────────────╯
# 本文件在 config 中通过 `config-file` 启用；切回 Ghostty 原生管理请改
# config-file = modules/keys-native.config
#
# 本模式下 Ghostty 不再绑定 tab / 分屏键，全部透传给 tmux。
# tmux 负责：ctrl+alt+hjkl 切 pane（条件 bind 按 @pane-is-vim 透传 nvim 或 select-pane）、
#            ctrl+shift+t / ctrl+1..8 / ctrl+shift+w 切 window
#
# 约定：tmux 模式下不使用 Ghostty 原生 tab/split（用 tmux 的 window/pane 代替），
#       启动时一般直接跑 `tmux new-session -A` 进入主 session


# --- split / pane 键处理：minus 显式透传给 tmux，其余原生键 unbind ---
# 如果需要偶尔用 Ghostty 原生 split，把下面这些行注释掉即可
# minus 显式发 CSI-u（45;7u），与 kitty send_text / wezterm 对齐；
# macOS 实测 unbind 写法经 modifyOtherKeys 路径也可用，这里取显式写法保持三终端一致
keybind = ctrl+alt+minus=text:\x1b[45;7u
keybind = ctrl+alt+backslash=unbind
keybind = ctrl+alt+w=unbind
keybind = ctrl+alt+h=unbind
keybind = ctrl+alt+j=unbind
keybind = ctrl+alt+k=unbind
keybind = ctrl+alt+l=unbind
keybind = ctrl+alt+left=unbind
keybind = ctrl+alt+right=unbind
keybind = ctrl+alt+up=unbind
keybind = ctrl+alt+down=unbind

# --- 透传 tab 管理键给 tmux（显式 CSI u，对齐终端原生快捷键体验）---
# 为什么显式发 CSI u 而不是 unbind：
#   unbind 后 Ghostty 走 legacy 编码（ctrl+1 → '1'，ctrl+shift+t → 'T'），
#   tmux 无法与普通输入区分，bind-key -n C-1 / C-S-t 不会触发。
#   显式发 CSI u 绕开协议协商，tmux 的 extended-keys 直接识别。
# 格式：\x1b[<codepoint>;<modifier>u
#   modifier = 1 + Shift(1) + Alt(2) + Ctrl(4)
#   116='t' 119='w' 49..56='1'..'8'；Ctrl+Shift=6，Ctrl=5
keybind = ctrl+tab=text:\x1b[9;5u
keybind = ctrl+shift+t=text:\x1b[116;6u
keybind = ctrl+shift+w=text:\x1b[119;6u
keybind = ctrl+1=text:\x1b[49;5u
keybind = ctrl+2=text:\x1b[50;5u
keybind = ctrl+3=text:\x1b[51;5u
keybind = ctrl+4=text:\x1b[52;5u
keybind = ctrl+5=text:\x1b[53;5u
keybind = ctrl+6=text:\x1b[54;5u
keybind = ctrl+7=text:\x1b[55;5u
keybind = ctrl+8=text:\x1b[56;5u
