# ╭─────────────────────────────────────────────────────╮
# │              窗口 / Shell / 鼠标                     │
# ╰─────────────────────────────────────────────────────╯

# 窗口无标题栏（macOS: transparent | hidden | tabs | native）
macos-titlebar-style = hidden

# 窗口内边距
window-padding-x = 0
window-padding-y = 0

# 窗口装饰
window-decoration = auto

# 选中即复制到剪贴板
copy-on-select = clipboard

# 初始窗口尺寸
window-width = 160
window-height = 45

# 跨平台启动目录（Mac/Linux/WSL 检测）
command = shell:~/.config/ghostty/scripts/launch.sh

# 右键粘贴
right-click-action = paste

# Shift+点击转发给 nvim（默认 false = 终端吞 Shift 做选区扩展）
# always = 始终把 Shift 送给 app，即使 app 通过 XTSHIFTESCAPE 要回去也不放
mouse-shift-capture = always

# Shell integration（让 Ghostty 感知命令开始/结束，通知依赖此项）
shell-integration = detect
shell-integration-features = cursor,sudo,title

# 关闭窗口不提示
confirm-close-surface = false

# macOS
macos-option-as-alt = true
quit-after-last-window-closed = true
