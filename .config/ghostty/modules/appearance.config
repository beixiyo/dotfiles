# ╭─────────────────────────────────────────────────────╮
# │              主题 / 光标 / 字体 / 透明度              │
# ╰─────────────────────────────────────────────────────╯

theme = Catppuccin Mocha

# 光标样式：block | bar | underline | block_hollow
cursor-style = block
cursor-style-blink = false
cursor-color = #52ad99

# 提升 macOS 上的字体对比度（CoreText 默认偏细）
font-thicken = true
# font-thicken-strength = 200

# 强制前景/背景最小对比度（1 = 不强制）
minimum-contrast = 1

# 色彩空间
window-colorspace = srgb

# 背景透明度与模糊
background-opacity = 0.9
background-blur = 7

# 非活动分屏不变暗
unfocused-split-opacity = 1.0

# 字体
font-family = "Maple Mono NF"
font-size = 12
