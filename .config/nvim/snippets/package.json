{
  "name": "nvim-snippets",
  "contributes": {
    "snippets": [
      { "language": ["css"], "path": "./css.json" },
      { "language": ["html"], "path": "./html.json" },
      { "language": ["java"], "path": "./java.json" },
      { "language": ["markdown"], "path": "./markdown.json" },
      { "language": ["scss"], "path": "./scss.json" },
      { "language": ["shellscript", "sh", "bash"], "path": "./shellscript.json" },
      { "language": ["vue"], "path": "./vue.json" },
      { "language": ["javascript", "typescript", "javascriptreact", "typescriptreact"], "path": "./jts.code-snippets" },
      { "language": ["typescriptreact", "javascriptreact"], "path": "./jtsx.code-snippets" },
      { "language": ["glsl", "hlsl", "wgsl"], "path": "./shader.code-snippets" },
      {
        "language": [
          "javascript", "typescript", "javascriptreact", "typescriptreact",
          "vue", "java", "cpp", "python", "kotlin", "shellscript"
        ],
        "path": "./global.code-snippets"
      }
    ]
  }
}
