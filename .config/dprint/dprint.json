{
  "indentWidth": 2,
  "lineWidth": 120,
  "typescript": {
    "semiColons": "asi",
    "quoteStyle": "alwaysSingle",
    "quoteProps": "asNeeded",
    "jsxExpressionContainer.spaceSurroundingExpression": true,
    "nextControlFlowPosition": "nextLine",
    "trailingCommas": "onlyMultiLine",
    "bracePosition": "sameLine",
    "singleBodyPosition": "sameLine",
    "jsx.bracketPosition": "nextLine",
    "jsx.quoteStyle": "preferDouble",
    "jsxSelfClosingElement.spaceBeforeSlash": true,
    "arrowFunction.useParentheses": "preferNone",
    "newLineKind": "lf",
    "useTabs": false
  },
  "json": {
  },
  "markdown": {
  },
  "malva": {
  },
  "markup": {
  },
  "yaml": {
  },
  "toml": {
  },
  "excludes": [
    "**/node_modules",
    "**/*-lock.json",
    "**/lock.json"
  ],
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.96.1.wasm",
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/markdown-0.22.1.wasm",
    "https://plugins.dprint.dev/g-plane/malva-v0.16.0.wasm",
    "https://plugins.dprint.dev/g-plane/markup_fmt-v0.27.3.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
    "https://plugins.dprint.dev/toml-0.7.0.wasm"
  ]
}
