{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ~/.claude/hooks/deny-compound-bypass.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ~/.claude/hooks/post-write-code.ts",
            "timeout": 30
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.zsh/notify/main.sh 'Codex needs you'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
